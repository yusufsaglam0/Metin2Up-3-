import os
import logging
import uuid
import asyncio
from datetime import datetime, timezone
from pathlib import Path
from typing import List, Optional
from fastapi import FastAPI, APIRouter, HTTPException
from fastapi.middleware.cors import CORSMiddleware
from fastapi.staticfiles import StaticFiles
from fastapi.responses import FileResponse
from pydantic import BaseModel, Field, ConfigDict
from motor.motor_asyncio import AsyncIOMotorClient
from dotenv import load_dotenv
import bcrypt

ROOT_DIR = Path(__file__).parent
load_dotenv(ROOT_DIR / '.env')

mongo_url = os.environ.get('MONGO_URL', 'mongodb://127.0.0.1:27017')
client = AsyncIOMotorClient(mongo_url)
db = client[os.environ.get('DB_NAME', 'metin2up')]

users = db.users
categories_db = db.categories
threads_db = db.threads
comments_db = db.comments

app = FastAPI()

# CORS Ayarları (Ön yüzün arka yüze sorunsuz bağlanabilmesi için)
app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

api_router = APIRouter(prefix="/api")

class UserRegister(BaseModel):
    username: str
    email: str
    password: str

class UserLogin(BaseModel):
    username: str
    password: str

class ThreadCreate(BaseModel):
    title: str
    content: str
    author: str

class ThreadUpdate(BaseModel):
    title: str
    content: str
    isPinned: bool

class CommentCreate(BaseModel):
    content: str
    author: str

class CategoryCreate(BaseModel):
    name: str
    desc: str
    tags: Optional[str] = "Genel, Tartışma"

class CategoryUpdate(BaseModel):
    name: str
    desc: str
    tags: str
    isHidden: bool
    isLocked: bool

@api_router.get("/forum-data")
async def get_forum_data():
    try:
        cats_cursor = categories_db.find({})
        raw_cats = await cats_cursor.to_list(length=100)
        users_task = users.count_documents({})
        threads_task = threads_db.count_documents({})
        total_users, total_threads = await asyncio.gather(users_task, threads_task)
        
        cats = []
        for doc in raw_cats:
            cat_id = doc.get("id")
            real_thread_count = await threads_db.count_documents({"category_id": cat_id})
            cats.append({
                "id": cat_id, 
                "name": doc.get("name"), 
                "desc": doc.get("desc", doc.get("description", "")),
                "tags": doc.get("tags", "Genel, Tartışma"),
                "icon": doc.get("icon", "💬"),
                "isHidden": doc.get("isHidden", False),
                "isLocked": doc.get("isLocked", False),
                "threadsCount": real_thread_count,
                "viewersCount": doc.get("viewersCount", 1)
            })
        return {"categories": cats, "stats": {"totalMembers": total_users, "totalThreads": total_threads}}
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))

@api_router.post("/admin/categories")
async def create_category(cat_data: CategoryCreate):
    try:
        new_cat = {"id": "cat_" + str(uuid.uuid4())[:8], "name": cat_data.name, "desc": cat_data.desc, "tags": cat_data.tags, "icon": "💬", "isHidden": False, "isLocked": False, "viewersCount": 1}
        await categories_db.insert_one(new_cat)
        if "_id" in new_cat:
            del new_cat["_id"]
        return new_cat
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))

@api_router.post("/admin/categories/{cat_id}/update")
async def update_category_settings(cat_id: str, cat_update: CategoryUpdate):
    try:
        await categories_db.update_one({"id": cat_id}, {"$set": {"name": cat_update.name, "desc": cat_update.desc, "tags": cat_update.tags, "isHidden": cat_update.isHidden, "isLocked": cat_update.isLocked}})
        return {"success": True}
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))

@api_router.delete("/admin/categories/{cat_id}")
async def delete_category_db(cat_id: str):
    try:
        await categories_db.delete_one({"id": cat_id})
        await threads_db.delete_many({"category_id": cat_id})
        return {"success": True}
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))

@api_router.get("/categories/{category_id}/threads")
async def get_threads(category_id: str):
    try:
        threads_list = []
        cursor = threads_db.find({"category_id": category_id})
        async for doc in cursor:
            threads_list.append({
                "id": doc["id"], 
                "category_id": doc["category_id"], 
                "title": doc["title"], 
                "content": doc.get("content", ""),
                "author": doc.get("author", "Anonim"),
                "isPinned": doc.get("isPinned", False)
            })
        return threads_list
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))

@api_router.post("/categories/{category_id}/threads")
async def create_thread(category_id: str, thread_data: ThreadCreate):
    try:
        new_thread = {
            "id": "th_" + str(uuid.uuid4())[:8], 
            "category_id": category_id, 
            "title": thread_data.title, 
            "content": thread_data.content, 
            "author": thread_data.author,
            "isPinned": False
        }
        await threads_db.insert_one(new_thread)
        if "_id" in new_thread:
            del new_thread["_id"]
        return new_thread
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))

@api_router.post("/threads/{thread_id}/update")
async def update_thread_db(thread_id: str, t_up: ThreadUpdate):
    try:
        await threads_db.update_one({"id": thread_id}, {"$set": {"title": t_up.title, "content": t_up.content, "isPinned": t_up.isPinned}})
        return {"success": True}
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))

@api_router.delete("/threads/{thread_id}")
async def delete_thread_db(thread_id: str):
    try:
        await threads_db.delete_one({"id": thread_id})
        await comments_db.delete_many({"thread_id": thread_id})
        return {"success": True}
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))

@api_router.post("/login")
async def login(user_data: UserLogin):
    user = await users.find_one({"username": user_data.username})
    if not user: raise HTTPException(status_code=400, detail="Kullanıcı bulunamadı.")
    if not bcrypt.checkpw(user_data.password.encode('utf-8'), user["password"].encode('utf-8')): raise HTTPException(status_code=400, detail="Hatalı şifre.")
    role = "admin" if user["username"].lower() == "metin2up" else user.get("role", "user")
    return {"success": True, "username": user["username"], "role": role}

@api_router.post("/register")
async def register(user_data: UserRegister):
    existing = await users.find_one({"$or": [{"username": user_data.username}, {"email": user_data.email}]})
    if existing: raise HTTPException(status_code=400, detail="Kullanıcı adı veya e-posta zaten kullanımda.")
    hashed = bcrypt.hashpw(user_data.password.encode('utf-8'), bcrypt.gensalt()).decode('utf-8')
    role = "admin" if user_data.username.lower() == "metin2up" else "user"
    await users.insert_one({"id": str(uuid.uuid4()), "username": user_data.username, "email": user_data.email, "password": hashed, "role": role})
    return {"success": True}

@api_router.get("/threads/{thread_id}/comments")
async def get_comments(thread_id: str):
    try:
        comments_list = []
        cursor = comments_db.find({"thread_id": thread_id})
        async for doc in cursor:
            comments_list.append({"id": doc["id"], "thread_id": doc["thread_id"], "content": doc["content"], "author": doc.get("author", "Anonim")})
        return comments_list
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))

@api_router.post("/threads/{thread_id}/comments")
async def create_comment(thread_id: str, comment_data: CommentCreate):
    try:
        new_comment = {"id": str(uuid.uuid4()), "thread_id": thread_id, "content": comment_data.content, "author": comment_data.author}
        await comments_db.insert_one(new_comment)
        if "_id" in new_comment:
            del new_comment["_id"]
        return new_comment
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))

# Rotaları uygulamaya dahil etme
app.include_router(api_router)

# React ön yüz klasörünün sunucuya tanıtılması
frontend_dist = Path(__file__).parent.parent / "frontend" / "dist"

if frontend_dist.exists():
    app.mount("/", StaticFiles(directory=str(frontend_dist), html=True), name="frontend")
    
    @app.exception_handler(404)
    async def not_found_handler(request, exc):
        return FileResponse(frontend_dist / "index.html")
if __name__ == "__main__":
    import uvicorn
    uvicorn.run("server:app", host="0.0.0.0", port=, reload=True)
